# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kapiva
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_USER=root
MONGO_PASS=root

# FastAPI
ENV=development

# Pedidos Chegando: limit PDFs per sync for testing (e.g. 3). Set 0 or leave unset to process all.
# PEDIDOS_CHEGANDO_MAX_PDFS=3
# Sync fetches up to 100 emails (regular) or 200 (importar histórico).
# When true, orders with confidence >= threshold auto-confirm. When false (default), all new orders need manual review.
# PEDIDOS_AUTO_CONFIRM=false
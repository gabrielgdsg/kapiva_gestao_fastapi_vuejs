# Copy to .env.network and adjust for network deployment
# docker-compose.network.yml overrides POSTGRES_HOST and MONGODB_URL

# PostgreSQL (overridden by compose when using local postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=LOGTEC
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB (overridden by compose when using local mongo)
MONGODB_URL=mongodb://mongo:27017

# FastAPI
UVICORN_HOST=0.0.0.0
ENV=production

# CORS - allow access from any PC on the network
ALLOWED_ORIGINS=*

# Optional: Pedidos Chegando (Gmail)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GMAIL_ADDRESS=
# GEMINI_API_KEY=
